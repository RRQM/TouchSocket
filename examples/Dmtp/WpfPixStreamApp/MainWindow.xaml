<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="DMTP PixStream 演示" Height="360" Width="520">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="DMTP PixStream 演示" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <GroupBox Grid.Row="1" Header="选择演示场景" Margin="0,0,0,10" Padding="8,4">
            <StackPanel>
                <RadioButton x:Name="rbScenario1" GroupName="Scenario" IsChecked="True" Margin="0,4">
                    <TextBlock Text="场景一：服务器采集，客户端直连显示" TextWrapping="Wrap"/>
                </RadioButton>
                <RadioButton x:Name="rbScenario2" GroupName="Scenario" Margin="0,4">
                    <TextBlock Text="场景二：客户端采集，服务器主动拉取" TextWrapping="Wrap"/>
                </RadioButton>
                <RadioButton x:Name="rbScenario3" GroupName="Scenario" Margin="0,4">
                    <TextBlock Text="场景三：两客户端间路由传输" TextWrapping="Wrap"/>
                </RadioButton>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="监听地址：" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtAddress" Text="127.0.0.1:9789" VerticalAlignment="Center" FontWeight="SemiBold"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="状态：" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtStatus" Text="未启动" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="采集帧率：" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtCaptureStatus" Text="—" VerticalAlignment="Center" Foreground="Gray"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,8"
                    x:Name="panelCaptureId" Visibility="Collapsed">
            <TextBlock Text="采集端 ID：" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtCaptureClientId" Text="—" VerticalAlignment="Center"
                       FontWeight="SemiBold" Foreground="DarkBlue"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="btnStart" Content="启动" Width="80" Height="30"
                    Click="BtnStart_Click" Margin="0,0,8,0"/>
            <Button x:Name="btnOpenView" Content="打开显示窗口" Width="120" Height="30"
                    IsEnabled="False" Visibility="Collapsed" Click="BtnOpenView_Click"/>
        </StackPanel>

        <!-- 场景二：服务器本地显示区域 -->
        <Grid Grid.Row="7" x:Name="gridServerDisplay" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="txtFrameInfo2" Text="等待采集端连接…" Foreground="Gray" Margin="0,0,0,4"/>
            <Image Grid.Row="1" x:Name="imgDisplay2" Stretch="Uniform" MinHeight="300"/>
        </Grid>
    </Grid>
</Window>
